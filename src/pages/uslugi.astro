---
import BaseLayout from '../layouts/BaseLayout.astro';
import PhotoFrame from '../components/PhotoFrame.astro';
import ContactForm from '../components/ContactForm.astro';

import b2b1 from '../assets/images/placeholders/b2b-01.jpg';
import b2b2 from '../assets/images/placeholders/b2b-02.jpg';
import b2b3 from '../assets/images/placeholders/b2b-03.jpg';

// ✏️ Uzupełnij ceny pakietów (per SKU) — to zwykły tekst, żadnego kodu.
const packages = [
  {
    name: 'Packshot',
    price: '[CENA ✏️] zł / SKU',
    desc: 'Czysty kadr produktu na jednolitym tle — do sklepu internetowego i katalogu.',
    features: ['3 ujęcia na SKU', 'białe lub czarne tło', 'pliki przygotowane pod web', 'podstawowy retusz'],
  },
  {
    name: 'Packshot + aranżacja',
    price: '[CENA ✏️] zł / SKU',
    desc: 'Produkt w kontekście — stylizowane sceny, które sprzedają nastrój, nie tylko przedmiot.',
    features: ['5 ujęć na SKU', 'stylizacja i sceneria', 'pliki web + druk', 'pełny retusz'],
  },
  {
    name: 'Sesja autorska',
    price: 'wycena indywidualna',
    desc: 'Kierunkowe światło i makrodetal — język wizualny Revelare zastosowany do Twojego produktu.',
    features: ['koncepcja i kierunek artystyczny', 'ujęcia makro detali', 'licencja rozszerzona', 'zakres ustalany wspólnie'],
  },
];

const gallery = [
  { image: b2b1, alt: 'Przykładowa fotografia produktowa — placeholder' },
  { image: b2b2, alt: 'Przykładowa fotografia produktowa w aranżacji — placeholder' },
  { image: b2b3, alt: 'Przykładowy makrodetal produktu — placeholder' },
];
---

<BaseLayout
  title="Fotografia produktowa B2B | Revelare"
  description="Fotografia produktowa dla firm z Częstochowy i okolic — packshoty, aranżacje i sesje autorskie z makrodetalem. Wycena per SKU."
>
  <div class="mx-auto max-w-6xl px-5 md:px-8">
    <header class="max-w-2xl pb-14 md:pb-20">
      <p class="kicker mb-3">Usługi B2B</p>
      <h1 class="display text-5xl md:text-6xl">Fotografia produktowa</h1>
      <p class="mt-5 text-moss">
        Warsztat z makrofotografii — precyzyjne światło, ostrość i detal — w służbie Twojego
        produktu. Pracuję stacjonarnie w Częstochowie i okolicach.
      </p>
    </header>

    <!-- Pakiety. -->
    <section aria-labelledby="pakiety" class="pb-20">
      <h2 id="pakiety" class="kicker mb-8">Pakiety</h2>
      <div class="grid gap-6 md:grid-cols-3">
        {
          packages.map((pkg) => (
            <article class="flex flex-col border border-line bg-night-raised p-7">
              <h3 class="display text-2xl">{pkg.name}</h3>
              <p class="tech mt-2 !text-[0.75rem] !text-bone">{pkg.price}</p>
              <p class="mt-4 text-sm text-moss">{pkg.desc}</p>
              <ul class="mt-5 flex-1 space-y-1.5 text-sm text-moss">
                {pkg.features.map((f) => (
                  <li class="border-t border-line pt-1.5">{f}</li>
                ))}
              </ul>
              <a href="#zapytanie" class="btn mt-7">Zapytaj o wycenę</a>
            </article>
          ))
        }
      </div>
    </section>

    <!-- Mini-galeria komercyjna. -->
    <section aria-labelledby="galeria-b2b" class="pb-20">
      <h2 id="galeria-b2b" class="kicker mb-8">Przykładowe realizacje</h2>
      <div class="grid gap-6 sm:grid-cols-3">
        {gallery.map((g) => <PhotoFrame image={g.image} alt={g.alt} aspect="3 / 2" sizes="(min-width: 640px) 33vw, 100vw" />)}
      </div>
      <p class="tech mt-4 !text-[0.68rem]">[PLACEHOLDERY — tu trafią kadry komercyjne ✏️]</p>
    </section>

    <!-- Formularz zapytania. -->
    <section id="zapytanie" aria-labelledby="zapytanie-title" class="max-w-2xl scroll-mt-28">
      <h2 id="zapytanie-title" class="display mb-3 text-3xl">Zapytanie o wycenę</h2>
      <p class="mb-8 text-sm text-moss">
        Napisz, co fotografujemy (liczba SKU, terminy, gdzie zdjęcia będą używane) — wrócę
        z konkretną wyceną w 1–2 dni robocze.
      </p>
      <ContactForm subject="Zapytanie B2B — fotografia produktowa" id="form-b2b" />
    </section>
  </div>
</BaseLayout>
