---
import BaseLayout from '../layouts/BaseLayout.astro';

const links = [
  { label: 'GitHub', href: 'https://github.com/suchysuchysuchy' },
  { label: 'YouTube', href: 'https://www.youtube.com/@TheSuchySuchySuchy' },
];
---

<BaseLayout title="Contact — bart'sideas" description="Get in touch — email, GitHub, YouTube.">
  <section class="contact">
    <div class="container">
      <div class="contact-inner fade-up">
        <p class="section-label">Say hello</p>
        <h1 class="section-title">Contact</h1>

        <p class="contact-text">
          Got a question, want to collaborate, or just want to say hi?
        </p>

        <a href="mailto:bartsideas@gmail.com" class="contact-email">
          bartsideas@gmail.com
        </a>

        <div class="contact-links">
          {links.map((link) => (
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              class="contact-link"
            >
              {link.label}
              <span class="contact-link-arrow">↗</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact {
    padding-top: calc(var(--nav-height) + var(--space-xl));
    padding-bottom: var(--space-xl);
    min-height: 100vh;
    display: flex;
    align-items: center;
  }

  .contact-inner {
    max-width: 520px;
  }

  .contact-text {
    font-size: 1.05rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: var(--space-lg);
  }

  .contact-email {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 1.1rem;
    color: var(--color-accent);
    border-bottom: 1px solid rgba(107, 138, 255, 0.3);
    padding-bottom: 2px;
    transition: border-color 0.2s ease, color 0.2s ease;
    margin-bottom: var(--space-lg);
  }

  .contact-email:hover {
    color: var(--color-text);
    border-color: var(--color-text);
  }

  .contact-links {
    display: flex;
    gap: var(--space-md);
  }

  .contact-link {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    gap: 4px;
    transition: color 0.2s ease;
  }

  .contact-link:hover {
    color: var(--color-accent);
  }

  .contact-link-arrow {
    font-size: 0.7rem;
    opacity: 0;
    transform: translateY(2px);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .contact-link:hover .contact-link-arrow {
    opacity: 1;
    transform: translateY(0);
  }
</style>
