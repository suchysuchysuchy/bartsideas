---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PhotoFrame from '../components/PhotoFrame.astro';
import { SITE } from '../config';

import imgPortfolio from '../assets/images/placeholders/makro-02.jpg';
import imgWydruki from '../assets/images/ngc4565v1.jpg';
import imgUslugi from '../assets/images/placeholders/b2b-01.jpg';
import imgSzkolenia from '../assets/images/m52_v2.jpg';

const photos = await getCollection('photos');
const hero = photos.find((p) => p.data.hero) ?? photos[0];
const featured = photos
  .filter((p) => p.data.featured && (SITE.showPeopleSection || p.data.category !== 'ludzie'))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 6);

const entries = [
  {
    href: '/portfolio',
    title: 'Portfolio',
    sub: 'makro · astro · TLE',
    image: imgPortfolio,
    alt: 'Wejście do portfolio — kadr makro',
  },
  {
    href: '/wydruki',
    title: 'Wydruki',
    sub: 'fine art · edycje limitowane',
    image: imgWydruki,
    alt: 'Wejście do sklepu z wydrukami — galaktyka Igła',
  },
  {
    href: '/uslugi',
    title: 'Usługi',
    sub: 'produkt · lifestyle · wizerunek',
    image: imgUslugi,
    alt: 'Wejście do usług — fotografia produktowa i lifestyle',
  },
  {
    href: '/szkolenia',
    title: 'Szkolenia',
    sub: 'nauczę Cię · 1:1',
    image: imgSzkolenia,
    alt: 'Wejście do szkoleń — nauka astrofotografii i makro',
  },
];
---

<BaseLayout
  title="Revelare — Bartłomiej Suchanek · fotografia makro i astro"
  description="Revelare abscondita — ujawniać ukryte. Makrofotografia bezkręgowców Jury i astrofotografia rzadkich zjawisk TLE. Wydruki fine art, pliki cyfrowe, fotografia produktowa."
  ogImage={hero.data.image}
  padTop={false}
>
  <!-- Hero: jeden kadr na pełen ekran, wyłaniający się z czerni. -->
  <section class="relative h-[100dvh]">
    <div class="reveal-hero absolute inset-0">
      <PhotoFrame
        image={hero.data.image}
        alt={hero.data.alt}
        sizes="100vw"
        loading="eager"
        fetchpriority="high"
        reveal={false}
        aspect="auto"
        class="h-full w-full"
      />
    </div>
    <div class="absolute inset-0 bg-gradient-to-b from-night/60 via-night/20 to-night"></div>

    <div class="absolute inset-0 flex flex-col items-center justify-center px-6 text-center">
      <p class="kicker mb-6">Bartłomiej Suchanek · fotografia</p>
      <h1 class="display text-6xl sm:text-7xl md:text-8xl">{SITE.name}</h1>
      <p class="latin mt-4 text-xl text-moss sm:text-2xl">{SITE.motto}</p>
      <p class="tech mt-2 !text-[0.7rem]">{SITE.mottoTranslation}</p>
    </div>

    <a
      href="#wejscia"
      class="absolute bottom-8 left-1/2 flex h-11 w-11 -translate-x-1/2 items-center justify-center text-dim transition-colors hover:text-bone"
      aria-label="Przewiń w dół"
    >
      <svg width="12" height="28" viewBox="0 0 12 28" fill="none" aria-hidden="true">
        <path d="M6 0v26m0 0l5-5M6 26l-5-5" stroke="currentColor" stroke-width="1"></path>
      </svg>
    </a>
  </section>

  <!-- Cztery wejścia. -->
  <section id="wejscia" class="mx-auto max-w-6xl scroll-mt-24 px-5 py-20 md:px-8 md:py-28">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        entries.map((e) => (
          <a href={e.href} class="group relative block overflow-hidden">
            <PhotoFrame image={e.image} alt={e.alt} aspect="4 / 5" sizes="(min-width: 768px) 33vw, 100vw" />
            <span class="absolute inset-0 flex flex-col items-center justify-end bg-gradient-to-t from-night/85 via-night/10 to-transparent pb-8">
              <span class="display text-3xl transition-transform duration-500 group-hover:-translate-y-1">
                {e.title}
              </span>
              <span class="tech mt-1 !text-[0.68rem]">{e.sub}</span>
            </span>
          </a>
        ))
      }
    </div>
  </section>

  <!-- Wybrane prace. -->
  <section class="mx-auto max-w-6xl px-5 pb-4 md:px-8">
    <p class="kicker mb-2">Wybrane prace</p>
    <h2 class="display mb-10 text-4xl md:text-5xl">To, co ukryte</h2>

    <div class="columns-1 gap-6 sm:columns-2 lg:columns-3">
      {
        featured.map((p) => (
          <a href="/portfolio" class="group mb-6 block break-inside-avoid">
            <PhotoFrame image={p.data.image} alt={p.data.alt} />
            <span class="mt-3 block">
              <span class="block text-sm text-bone">{p.data.title}</span>
              {p.data.species && <span class="latin block text-sm text-moss">{p.data.species}</span>}
            </span>
          </a>
        ))
      }
    </div>

    <div class="mt-10">
      <a href="/portfolio" class="btn">Całe portfolio</a>
    </div>
  </section>

  <!-- Pas o marce. -->
  <section class="mx-auto max-w-3xl px-5 py-24 text-center md:px-8 md:py-32">
    <p class="latin text-2xl leading-relaxed text-bone md:text-3xl">„{SITE.motto}”</p>
    <p class="mt-6 text-moss">
      Ujawniać ukryte — bezkręgowce Jury, które mijamy nie widząc ich, i zjawiska nad burzami,
      które trwają krócej niż mrugnięcie. Fotografia jako akt odsłaniania.
    </p>
    <a href="/o-mnie" class="link-quiet mt-6 inline-block text-sm">O mnie i filozofii prac →</a>
  </section>
</BaseLayout>

<style>
  /* Wejście hero z czerni — animacja jasności zamiast opacity,
     żeby nie opóźniać LCP; wyłączana przy prefers-reduced-motion. */
  .reveal-hero {
    animation: hero-reveal 1.8s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  @keyframes hero-reveal {
    from {
      filter: brightness(0.15);
    }
    to {
      filter: brightness(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal-hero {
      animation: none;
    }
  }
</style>
