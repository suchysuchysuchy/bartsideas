---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

function readingTime(body: string): string {
  const words = body.split(/\s+/).length;
  const minutes = Math.ceil(words / 200);
  return `${minutes} min read`;
}
---

<BaseLayout title="Blog — bart'sideas" description="Thoughts on astrophotography, crafts, builds, and the night sky.">
  <section class="blog-page">
    <div class="container">
      <div class="blog-header fade-up">
        <p class="section-label">04 — Writing</p>
        <h1 class="section-title">Blog</h1>
      </div>

      <ul class="blog-list">
        {posts.map((post, i) => (
          <li class="fade-up" style={`--delay: ${i * 0.1}s`}>
            <a href={`/blog/${post.id}`} class="blog-item">
              <div class="blog-item-left">
                <time class="blog-date" datetime={post.data.date.toISOString()}>
                  {formatDate(post.data.date)}
                </time>
                <div>
                  <h2 class="blog-title">{post.data.title}</h2>
                  <p class="blog-desc">{post.data.description}</p>
                </div>
              </div>
              <div class="blog-item-right">
                <span class="blog-tag">{post.data.tag}</span>
                <span class="blog-read-time">{readingTime(post.body || '')}</span>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .blog-page {
    padding-top: calc(var(--nav-height) + var(--space-xl));
    padding-bottom: var(--space-xl);
    min-height: 100vh;
  }

  .blog-header {
    margin-bottom: var(--space-lg);
  }

  .blog-list {
    display: flex;
    flex-direction: column;
  }

  .blog-item {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    padding: var(--space-md) 0;
    border-bottom: 1px solid var(--color-border);
    transition: border-color var(--transition-fast);
    gap: var(--space-md);
  }

  .blog-list li:first-child .blog-item {
    border-top: 1px solid var(--color-border);
  }

  .blog-item:hover {
    border-color: var(--color-border-hover);
  }

  .blog-item-left {
    display: flex;
    gap: var(--space-md);
  }

  .blog-date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-dim);
    min-width: 100px;
    padding-top: 4px;
  }

  .blog-title {
    font-size: 1.3rem;
    font-family: var(--font-display);
    margin-bottom: 6px;
    transition: color var(--transition-fast);
  }

  .blog-item:hover .blog-title {
    color: var(--color-accent);
  }

  .blog-desc {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .blog-item-right {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    flex-shrink: 0;
    padding-top: 4px;
  }

  .blog-tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-accent-purple);
    background: rgba(160, 107, 255, 0.1);
    padding: 4px 10px;
    border-radius: 20px;
    white-space: nowrap;
  }

  .blog-read-time {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-dim);
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    .blog-item {
      flex-direction: column;
    }

    .blog-item-left {
      flex-direction: column;
      gap: 4px;
    }
  }
</style>
