---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    month: 'long',
    day: 'numeric',
    year: 'numeric',
  });
}

function readingTime(body: string): string {
  const words = body.split(/\s+/).length;
  const minutes = Math.ceil(words / 200);
  return `${minutes} min read`;
}
---

<BaseLayout title={`${post.data.title} — bart'sideas`} description={post.data.description}>
  <article class="post">
    <div class="container post-container">
      <header class="post-header fade-up">
        <a href="/blog" class="post-back">← Back to blog</a>
        <div class="post-meta">
          <span class="post-tag">{post.data.tag}</span>
          <time datetime={post.data.date.toISOString()}>
            {formatDate(post.data.date)}
          </time>
          <span>·</span>
          <span>{readingTime(post.body || '')}</span>
        </div>
        <h1 class="post-title">{post.data.title}</h1>
        <p class="post-desc">{post.data.description}</p>
      </header>

      <div class="post-content fade-up">
        <Content />
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .post {
    padding-top: calc(var(--nav-height) + var(--space-xl));
    padding-bottom: var(--space-xl);
  }

  .post-container {
    max-width: 720px;
  }

  .post-back {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
    transition: color var(--transition-fast);
  }

  .post-back:hover {
    color: var(--color-accent);
  }

  .post-header {
    margin-bottom: var(--space-lg);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-dim);
    margin-bottom: var(--space-md);
  }

  .post-tag {
    color: var(--color-accent-purple);
    background: rgba(160, 107, 255, 0.1);
    padding: 3px 8px;
    border-radius: 20px;
  }

  .post-title {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: var(--space-sm);
    line-height: 1.15;
  }

  .post-desc {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .post-content {
    line-height: 1.8;
    color: var(--color-text-muted);
  }

  .post-content :global(h2) {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 600;
    color: var(--color-text);
    margin: var(--space-lg) 0 var(--space-sm);
  }

  .post-content :global(h3) {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-text);
    margin: var(--space-md) 0 var(--space-sm);
  }

  .post-content :global(p) {
    margin-bottom: var(--space-sm);
  }

  .post-content :global(strong) {
    color: var(--color-text);
    font-weight: 600;
  }

  .post-content :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color var(--transition-fast);
  }

  .post-content :global(a:hover) {
    color: var(--color-accent-purple);
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    margin: var(--space-sm) 0;
    padding-left: var(--space-md);
  }

  .post-content :global(li) {
    margin-bottom: 8px;
    list-style: disc;
  }

  .post-content :global(ol li) {
    list-style: decimal;
  }

  .post-content :global(code) {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--color-bg-card);
    padding: 2px 6px;
    border-radius: 4px;
    color: var(--color-accent);
  }

  .post-content :global(pre) {
    background: var(--color-bg-card) !important;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-md);
    margin: var(--space-md) 0;
    overflow-x: auto;
  }

  .post-content :global(pre code) {
    background: none;
    padding: 0;
    border-radius: 0;
  }

  .post-content :global(blockquote) {
    border-left: 2px solid var(--color-accent);
    padding-left: var(--space-sm);
    margin: var(--space-md) 0;
    color: var(--color-text);
    font-style: italic;
  }

  .post-content :global(hr) {
    border: none;
    height: 1px;
    background: var(--color-border);
    margin: var(--space-lg) 0;
  }

  .post-content :global(img) {
    border-radius: var(--radius-md);
    margin: var(--space-md) 0;
  }
</style>
