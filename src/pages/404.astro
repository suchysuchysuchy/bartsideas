---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="404 — nie ujawniono | Revelare"
  description="Ta strona pozostaje ukryta."
>
  <div class="flex min-h-[55dvh] flex-col items-center justify-center px-6 text-center">
    <p class="tech mb-4">404</p>
    <h1 class="display text-4xl md:text-6xl">Nie wszystko zostaje ujawnione</h1>
    <p class="latin mt-4 text-lg text-moss">abscondita manent abscondita</p>
    <p class="mt-2 max-w-md text-sm text-dim">
      Ta strona nie istnieje — albo dotąd nie wyszła z ukrycia.
    </p>
    <a href="/" class="btn mt-10">Wróć na stronę główną</a>
  </div>
</BaseLayout>
