---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import { SITE, isRealLink } from '../config';

const socials = [
  { href: SITE.instagram, label: 'Instagram' },
  { href: SITE.inaturalist, label: 'iNaturalist' },
].filter((s) => isRealLink(s.href));
---

<BaseLayout
  title="Kontakt | Revelare"
  description="Napisz do mnie — zapytania o wydruki, licencje komercyjne i sesje produktowe. Bartłomiej Suchanek, Częstochowa."
>
  <div class="mx-auto max-w-6xl px-5 md:px-8">
    <header class="max-w-2xl pb-12">
      <p class="kicker mb-3">Kontakt</p>
      <h1 class="display text-5xl md:text-6xl">Napisz do mnie</h1>
      <p class="mt-5 text-moss">
        Wydruki, licencje komercyjne, sesje produktowe, współprace — odpowiadam zwykle
        w 1–2 dni robocze.
      </p>
    </header>

    <div class="grid gap-14 lg:grid-cols-2">
      <ContactForm />

      <aside class="space-y-8" aria-label="Dane kontaktowe">
        <div>
          <h2 class="kicker mb-2">E-mail</h2>
          <a href={`mailto:${SITE.email}`} class="link-quiet text-lg">{SITE.email}</a>
        </div>
        {
          socials.length > 0 && (
            <div>
              <h2 class="kicker mb-2">W sieci</h2>
              <ul class="space-y-1 text-sm">
                {socials.map((s) => (
                  <li>
                    <a class="link-quiet" href={s.href} rel="me noopener" target="_blank">
                      {s.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )
        }
        <div>
          <h2 class="kicker mb-2">Pracownia</h2>
          <p class="text-sm text-moss">{SITE.location}</p>
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>
