---
import { SITE } from '../config';

const links = [
  { href: '/portfolio', label: 'Portfolio' },
  { href: '/wydruki', label: 'Wydruki' },
  { href: '/pliki', label: 'Pliki' },
  { href: '/uslugi', label: 'Usługi' },
  { href: '/szkolenia', label: 'Szkolenia' },
  { href: '/o-mnie', label: 'O mnie' },
  { href: '/kontakt', label: 'Kontakt' },
];

// Ta sama normalizacja co canonical w BaseLayout — przy build.format 'file'
// pathname kończy się na ".html" i bez tego aria-current nigdy nie trafia.
const path = Astro.url.pathname.replace(/\/index\.html$/, '/').replace(/\.html$/, '') || '/';
const isActive = (href: string) => path === href || path.startsWith(href + '/');
---

<header class="fixed inset-x-0 top-0 z-40 border-b border-line/60 bg-night/80 backdrop-blur-md">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-5 md:h-20 md:px-8">
    <a href="/" class="display text-2xl tracking-wide md:text-3xl" aria-label="Revelare — strona główna">
      {SITE.name}
    </a>

    <nav class="desktop-nav hidden md:block" aria-label="Nawigacja główna">
      <ul class="flex items-center gap-8">
        {
          links.map((l) => (
            <li>
              <a
                href={l.href}
                aria-current={isActive(l.href) ? 'page' : undefined}
                class:list={[
                  'tech !text-[0.72rem] uppercase transition-colors hover:!text-bone',
                  isActive(l.href) ? '!text-bone' : '',
                ]}
              >
                {l.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <button
      id="nav-toggle"
      type="button"
      class="flex h-11 w-11 items-center justify-center text-bone md:hidden"
      aria-expanded="false"
      aria-controls="nav-menu"
      aria-label="Otwórz menu"
    >
      <svg width="22" height="14" viewBox="0 0 22 14" fill="none" aria-hidden="true">
        <path d="M0 1h22M0 7h22M0 13h22" stroke="currentColor" stroke-width="1.2"></path>
      </svg>
    </button>
  </div>
</header>

<div
  id="nav-menu"
  hidden
  class="fixed inset-0 z-50 flex flex-col bg-night/[0.97] px-6 py-5 backdrop-blur-sm md:hidden"
>
  <div class="flex items-center justify-between">
    <span class="display text-2xl tracking-wide">{SITE.name}</span>
    <button
      id="nav-close"
      type="button"
      class="flex h-11 w-11 items-center justify-center text-bone"
      aria-label="Zamknij menu"
    >
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <path d="M1 1l16 16M17 1L1 17" stroke="currentColor" stroke-width="1.2"></path>
      </svg>
    </button>
  </div>

  <nav class="flex flex-1 items-center" aria-label="Nawigacja mobilna">
    <ul class="space-y-6">
      {
        links.map((l) => (
          <li>
            <a
              href={l.href}
              aria-current={isActive(l.href) ? 'page' : undefined}
              class:list={['display block text-4xl', isActive(l.href) ? 'text-bone' : 'text-moss']}
            >
              {l.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>

  <p class="latin text-sm text-dim">{SITE.motto}</p>
</div>

<script>
  const toggle = document.getElementById('nav-toggle')!;
  const close = document.getElementById('nav-close')!;
  const menu = document.getElementById('nav-menu')!;

  const setOpen = (open: boolean) => {
    menu.hidden = !open;
    toggle.setAttribute('aria-expanded', String(open));
    document.documentElement.style.overflow = open ? 'hidden' : '';
    if (open) close.focus();
    else toggle.focus();
  };

  toggle.addEventListener('click', () => setOpen(true));
  close.addEventListener('click', () => setOpen(false));
  menu.addEventListener('click', (e) => {
    if ((e.target as HTMLElement).closest('a')) setOpen(false);
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !menu.hidden) setOpen(false);
  });

  // Pułapka fokusu: Tab krąży wewnątrz otwartego menu, nie ucieka pod overlay.
  menu.addEventListener('keydown', (e) => {
    if (e.key !== 'Tab') return;
    const focusables = menu.querySelectorAll<HTMLElement>('a[href], button');
    const first = focusables[0];
    const last = focusables[focusables.length - 1];
    if (e.shiftKey && document.activeElement === first) {
      e.preventDefault();
      last.focus();
    } else if (!e.shiftKey && document.activeElement === last) {
      e.preventDefault();
      first.focus();
    }
  });
</script>

<style>
  /* Bez JavaScriptu hamburger nie działa — pokaż wtedy zwykłą listę
     linków także na wąskich ekranach i schowaj martwy przycisk. */
  :global(html.no-js) #nav-toggle {
    display: none;
  }

  :global(html.no-js) .desktop-nav {
    display: block;
  }

  :global(html.no-js) .desktop-nav ul {
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.75rem 1.25rem;
  }

  :global(html.no-js) header > div {
    height: auto;
    min-height: 4rem;
    flex-wrap: wrap;
    row-gap: 0.5rem;
    padding-block: 0.75rem;
  }
</style>
