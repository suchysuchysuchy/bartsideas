---
/**
 * Kadr w galerii portfolio: otwiera lightbox (przycisk z pełnymi danymi
 * w atrybutach data-*) i podpisany jest zgodnie z konwencją:
 * tytuł · nazwa gatunkowa kursywą · lokalizacja · rok.
 */
import type { CollectionEntry } from 'astro:content';
import { getImage } from 'astro:assets';
import PhotoFrame from './PhotoFrame.astro';

interface Props {
  photo: CollectionEntry<'photos'>;
  sizes?: string;
}

const { photo, sizes } = Astro.props;
const { title, species, location, year, image, alt } = photo.data;

const full = await getImage({
  src: image,
  width: Math.min(image.width, 2048),
  format: 'webp',
});

const meta = [location, year].filter(Boolean).join(' · ');
---

<button
  type="button"
  class="group mb-8 block w-full break-inside-avoid text-left"
  data-lightbox
  data-full={full.src}
  data-title={title}
  data-species={species ?? ''}
  data-meta={meta}
  data-alt={alt}
  aria-label={`Powiększ: ${title}`}
>
  <PhotoFrame image={image} alt={alt} sizes={sizes} />
  <span class="mt-3 block px-0.5">
    <span class="block text-sm text-bone transition-colors group-hover:text-white">{title}</span>
    {species && <span class="latin block text-sm text-moss">{species}</span>}
    {meta && <span class="tech mt-1 block !text-[0.7rem]">{meta}</span>}
  </span>
</button>
