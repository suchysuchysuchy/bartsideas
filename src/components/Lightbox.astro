---
/**
 * Lightbox galerii: pełny ekran, obsługa klawiatury (Esc, ← →),
 * swipe na dotyku. Zbiera wszystkie [data-lightbox] ze strony.
 */
---

<dialog
  id="lightbox"
  class="m-auto h-full max-h-none w-full max-w-none bg-night/[0.98] p-0 backdrop:bg-night/90"
  aria-label="Podgląd zdjęcia"
>
  <div class="flex h-full w-full flex-col" id="lb-shell">
    <div class="flex items-center justify-end px-4 pt-4">
      <button
        type="button"
        id="lb-close"
        class="flex h-11 w-11 items-center justify-center text-moss transition-colors hover:text-bone"
        aria-label="Zamknij podgląd"
      >
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M1 1l16 16M17 1L1 17" stroke="currentColor" stroke-width="1.2"></path>
        </svg>
      </button>
    </div>

    <figure class="flex min-h-0 flex-1 flex-col items-center justify-center gap-4 px-4 pb-6">
      <img id="lb-img" src="" alt="" class="min-h-0 max-w-full flex-1 object-contain" />
      <figcaption class="text-center" aria-live="polite">
        <span id="lb-title" class="block text-sm text-bone"></span>
        <span id="lb-species" class="latin block text-sm text-moss"></span>
        <span id="lb-meta" class="tech mt-0.5 block !text-[0.7rem]"></span>
      </figcaption>
    </figure>

    <div class="flex items-center justify-center gap-10 pb-6">
      <button
        type="button"
        id="lb-prev"
        class="flex h-11 w-11 items-center justify-center text-moss transition-colors hover:text-bone"
        aria-label="Poprzednie zdjęcie"
      >
        <svg width="22" height="12" viewBox="0 0 22 12" fill="none" aria-hidden="true">
          <path d="M22 6H1m0 0l5-5M1 6l5 5" stroke="currentColor" stroke-width="1.2"></path>
        </svg>
      </button>
      <span id="lb-counter" class="tech !text-[0.7rem]"></span>
      <button
        type="button"
        id="lb-next"
        class="flex h-11 w-11 items-center justify-center text-moss transition-colors hover:text-bone"
        aria-label="Następne zdjęcie"
      >
        <svg width="22" height="12" viewBox="0 0 22 12" fill="none" aria-hidden="true">
          <path d="M0 6h21m0 0l-5-5m5 5l-5 5" stroke="currentColor" stroke-width="1.2"></path>
        </svg>
      </button>
    </div>
  </div>
</dialog>

<script>
  const dialog = document.getElementById('lightbox') as HTMLDialogElement;
  const img = document.getElementById('lb-img') as HTMLImageElement;
  const elTitle = document.getElementById('lb-title')!;
  const elSpecies = document.getElementById('lb-species')!;
  const elMeta = document.getElementById('lb-meta')!;
  const elCounter = document.getElementById('lb-counter')!;

  const triggers = [...document.querySelectorAll<HTMLElement>('[data-lightbox]')];
  let index = 0;

  const show = (i: number) => {
    index = (i + triggers.length) % triggers.length;
    const t = triggers[index];
    img.src = t.dataset.full ?? '';
    img.alt = t.dataset.alt ?? '';
    elTitle.textContent = t.dataset.title ?? '';
    elSpecies.textContent = t.dataset.species ?? '';
    elSpecies.style.display = t.dataset.species ? '' : 'none';
    elMeta.textContent = t.dataset.meta ?? '';
    elCounter.textContent = `${index + 1} / ${triggers.length}`;
  };

  triggers.forEach((t, i) =>
    t.addEventListener('click', () => {
      show(i);
      dialog.showModal();
    }),
  );

  document.getElementById('lb-close')!.addEventListener('click', () => dialog.close());
  document.getElementById('lb-prev')!.addEventListener('click', () => show(index - 1));
  document.getElementById('lb-next')!.addEventListener('click', () => show(index + 1));

  dialog.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowLeft') show(index - 1);
    if (e.key === 'ArrowRight') show(index + 1);
  });

  // Klik w tło (poza obrazem i przyciskami) zamyka.
  dialog.addEventListener('click', (e) => {
    const el = e.target as HTMLElement;
    if (el === dialog || el.id === 'lb-shell' || el.tagName === 'FIGURE') dialog.close();
  });

  // Swipe w lewo/prawo na dotyku.
  let touchX = 0;
  dialog.addEventListener('touchstart', (e) => (touchX = e.changedTouches[0].clientX), {
    passive: true,
  });
  dialog.addEventListener(
    'touchend',
    (e) => {
      const dx = e.changedTouches[0].clientX - touchX;
      if (Math.abs(dx) > 48) show(index + (dx < 0 ? 1 : -1));
    },
    { passive: true },
  );
</script>
