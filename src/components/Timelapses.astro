---
const timelapses = [
  {
    title: 'Startrails in Częstochowa city centre',
    youtubeId: 'LZjbOY1_MdU',
    vertical: false,
  },
  {
    title: 'Crocus vernus',
    youtubeId: 'AQ4yF-b8wEY',
    vertical: true,
  },
];
---

<section id="timelapses" class="section">
  <div class="container">
    <div class="fade-up">
      <p class="section-label">02 — Motion</p>
      <h2 class="section-title">Timelapses</h2>
    </div>

    <div class="tl-list fade-up" id="tl-list">
      {timelapses.map((item) => (
        <div class="tl-item">
          <button class="tl-row">
            <span class="tl-play">
              <svg width="10" height="12" viewBox="0 0 10 12" fill="none">
                <path d="M1 1L9 6L1 11V1Z" fill="currentColor" />
              </svg>
            </span>
            <span class="tl-title">{item.title}</span>
          </button>
          <div class="tl-body">
            <div class="tl-body-content">
              <div class={`tl-embed ${item.vertical ? 'tl-embed--vertical' : ''}`}>
                <iframe
                  src={`https://www.youtube.com/embed/${item.youtubeId}`}
                  frameborder="0"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen
                  loading="lazy"
                ></iframe>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const list = document.getElementById('tl-list');
    if (!list) return;

    list.addEventListener('click', (e) => {
      const row = e.target.closest('.tl-row');
      if (!row) return;

      const item = row.closest('.tl-item');
      if (!item) return;

      const isOpen = item.classList.contains('open');

      // Close all open items
      list.querySelectorAll('.tl-item.open').forEach((el) => {
        el.classList.remove('open');
      });

      // Toggle clicked item
      if (!isOpen) {
        item.classList.add('open');
      }
    });
  });
</script>

<style>
  .tl-list {
    display: flex;
    flex-direction: column;
  }

  .tl-item {
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .tl-row {
    display: flex;
    align-items: center;
    gap: 14px;
    width: 100%;
    padding: 14px 0;
    cursor: pointer;
    background: none;
    border: none;
    color: var(--color-text);
    font-family: inherit;
    transition: color 0.2s ease;
  }

  .tl-row:hover {
    color: var(--color-accent);
  }

  .tl-play {
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-dim);
    flex-shrink: 0;
    transition: transform 0.3s ease, color 0.2s ease;
  }

  .tl-item.open .tl-play {
    transform: rotate(90deg);
    color: var(--color-accent);
  }

  .tl-row:hover .tl-play {
    color: var(--color-accent);
  }

  .tl-title {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 400;
    text-align: left;
  }

  /* Accordion body */
  .tl-body {
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    transition: max-height 0.4s ease, opacity 0.3s ease;
  }

  .tl-item.open .tl-body {
    max-height: 700px;
    opacity: 1;
  }

  .tl-body-content {
    padding: 0 0 20px 38px;
  }

  /* Embed wrapper */
  .tl-embed {
    position: relative;
    width: 100%;
    max-width: 800px;
    aspect-ratio: 16 / 9;
    margin-top: 12px;
    border-radius: 8px;
    overflow: hidden;
  }

  .tl-embed--vertical {
    aspect-ratio: 9 / 16;
    max-width: 350px;
  }

  .tl-embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
    border-radius: 8px;
  }
</style>
