---
// Generate star positions deterministically
const stars = Array.from({ length: 80 }, (_, i) => ({
  left: `${(i * 37 + 13) % 100}%`,
  top: `${(i * 53 + 7) % 100}%`,
  size: `${1 + (i % 3)}px`,
  duration: `${3 + (i % 5)}s`,
  delay: `${(i % 7) * 0.5}s`,
  maxOpacity: 0.3 + (i % 4) * 0.2,
}));
---

<div class="stars-canvas">
  {stars.map((star) => (
    <div
      class="star"
      style={`left:${star.left};top:${star.top};width:${star.size};height:${star.size};--duration:${star.duration};--delay:${star.delay};--max-opacity:${star.maxOpacity}`}
    />
  ))}
</div>
