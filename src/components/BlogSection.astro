---
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog').catch(() => []);
const posts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

function readingTime(body: string): string {
  const words = body.split(/\s+/).length;
  const minutes = Math.ceil(words / 200);
  return `${minutes} min read`;
}
---

<section id="blog" class="section">
  <div class="container">
    <div class="fade-up">
      <p class="section-label">04 — Writing</p>
      <h2 class="section-title">Blog</h2>
    </div>

    {posts.length > 0 ? (
      <ul class="blog-list">
        {posts.map((post, i) => (
          <li class="fade-up" style={`--delay: ${i * 0.1}s`}>
            <a href={`/blog/${post.id}`} class="blog-item">
              <div class="blog-item-left">
                <time class="blog-date" datetime={post.data.date.toISOString()}>
                  {formatDate(post.data.date)}
                </time>
                <h3 class="blog-title">{post.data.title}</h3>
              </div>
              <div class="blog-item-right">
                <span class="blog-tag">{post.data.tag}</span>
                <span class="blog-read-time">{readingTime(post.body || '')}</span>
              </div>
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <p class="blog-empty fade-up">Coming soon</p>
    )}
  </div>
</section>

<style>
  .blog-empty {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-text-dim);
  }

  .blog-list {
    display: flex;
    flex-direction: column;
  }

  .blog-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-md) 0;
    border-bottom: 1px solid var(--color-border);
    transition: border-color var(--transition-fast);
  }

  .blog-list li:first-child .blog-item {
    border-top: 1px solid var(--color-border);
  }

  .blog-item:hover {
    border-color: var(--color-border-hover);
  }

  .blog-item-left {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .blog-date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-dim);
    min-width: 100px;
  }

  .blog-title {
    font-size: 1.15rem;
    font-family: var(--font-display);
    transition: color var(--transition-fast);
  }

  .blog-item:hover .blog-title {
    color: var(--color-accent);
  }

  .blog-item-right {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    flex-shrink: 0;
  }

  .blog-tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-accent-purple);
    background: rgba(160, 107, 255, 0.1);
    padding: 4px 10px;
    border-radius: 20px;
  }

  .blog-read-time {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-dim);
  }

  .blog-cta {
    margin-top: var(--space-md);
    text-align: center;
  }

  .blog-cta-link {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-text-muted);
    transition: color var(--transition-fast);
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .blog-cta-link:hover {
    color: var(--color-accent);
  }

  .blog-cta-arrow {
    transition: transform var(--transition-fast);
  }

  .blog-cta-link:hover .blog-cta-arrow {
    transform: translateX(4px);
  }

  @media (max-width: 768px) {
    .blog-item {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-xs);
    }

    .blog-item-left {
      flex-direction: column;
      gap: 4px;
    }

    .blog-item-right {
      padding-left: 0;
    }
  }
</style>
