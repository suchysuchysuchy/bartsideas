---
import { SITE } from '../config';

const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-line">
  <div class="mx-auto max-w-6xl px-5 py-12 md:px-8">
    <p class="latin mb-10 text-lg text-dim">{SITE.motto}</p>

    <div class="flex flex-col gap-8 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="text-sm text-moss">© {year} {SITE.owner} · {SITE.name}</p>
        <p class="mt-1 text-sm text-dim">{SITE.location}</p>
      </div>

      <nav aria-label="Linki w stopce">
        <ul class="flex flex-wrap gap-x-6 gap-y-2 text-sm">
          <li><a class="link-quiet" href={SITE.instagram} rel="me noopener" target="_blank">Instagram</a></li>
          <li><a class="link-quiet" href={SITE.inaturalist} rel="me noopener" target="_blank">iNaturalist</a></li>
          <li><a class="link-quiet" href={`mailto:${SITE.email}`}>E-mail</a></li>
        </ul>
        <ul class="mt-3 flex flex-wrap gap-x-6 gap-y-2 text-sm">
          <li><a class="link-quiet" href="/regulamin">Regulamin</a></li>
          <li><a class="link-quiet" href="/polityka-prywatnosci">Prywatność</a></li>
          <li><a class="link-quiet" href="/odstapienie-od-umowy">Odstąpienie od umowy</a></li>
          <li><a class="link-quiet" href="/licencja">Licencja plików</a></li>
        </ul>
      </nav>
    </div>
  </div>
</footer>
