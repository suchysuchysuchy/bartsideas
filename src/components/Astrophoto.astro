---
import { Image } from 'astro:assets';
import Lightbox from './Lightbox.astro';

import ngc7000 from '../assets/images/NGC7000v11-2.jpg';
import m1 from '../assets/images/M1_v1.jpg';
import m52 from '../assets/images/m52_v2.jpg';
import ngc4565 from '../assets/images/ngc4565v1.jpg';

const photos = [
  { id: '01', title: 'North America Nebula', catalog: 'NGC 7000', integration: '11h+', gear: 'Seestar S50', image: ngc7000 },
  { id: '02', title: 'Crab Nebula', catalog: 'M1', integration: '', gear: 'Seestar S50', image: m1 },
  { id: '03', title: 'Messier 52', catalog: 'M52', integration: '', gear: 'Seestar S50', image: m52 },
  { id: '04', title: 'Needle Galaxy', catalog: 'NGC 4565', integration: '', gear: 'Seestar S50', image: ngc4565 },
];
---

<section id="astrophoto" class="section">
  <div class="container">
    <div class="fade-up">
      <p class="section-label">01 — Gallery</p>
      <h2 class="section-title">Astrophoto</h2>
    </div>

    <div class="astro-grid fade-up">
      {photos.map((photo) => (
        <button
          class="astro-card"
          data-photo={JSON.stringify({
            title: photo.title,
            catalog: photo.catalog,
            integration: photo.integration,
            gear: photo.gear,
            imageSrc: typeof photo.image === 'object' ? photo.image.src : photo.image,
          })}
          aria-label={`View ${photo.title}`}
        >
          <Image
            src={photo.image}
            alt={photo.title}
            width={600}
            loading="eager"
            class="astro-card-img"
          />
          <span class="astro-card-number">#{photo.id}</span>
          <div class="astro-card-label">
            <span class="astro-card-name">{photo.title}</span>
            <span class="astro-card-meta">
              {photo.catalog}{photo.integration ? ` · ${photo.integration}` : ''} · {photo.gear}
            </span>
          </div>
        </button>
      ))}
    </div>
  </div>
</section>

<Lightbox />

<style>
  .astro-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .astro-card {
    position: relative;
    aspect-ratio: 4 / 3;
    border-radius: 12px;
    overflow: hidden;
    cursor: pointer;
    border: 1px solid var(--color-border);
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    background: #111320;
    padding: 0;
    display: block;
    width: 100%;
  }

  .astro-card:hover {
    transform: scale(1.02);
    border-color: var(--color-border-hover);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4);
  }

  .astro-card-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: filter 0.3s ease;
  }

  .astro-card:hover .astro-card-img {
    filter: brightness(1.1);
  }

  .astro-card-number {
    position: absolute;
    top: 12px;
    right: 14px;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: rgba(255, 255, 255, 0.35);
    z-index: 1;
  }

  .astro-card-label {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 24px 16px 14px;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.7), transparent);
    display: flex;
    flex-direction: column;
    gap: 3px;
    z-index: 1;
  }

  .astro-card-name {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text);
  }

  .astro-card-meta {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.5);
  }

  @media (max-width: 768px) {
    .astro-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .astro-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
